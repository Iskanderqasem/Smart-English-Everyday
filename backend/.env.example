# ======================================================
# Smart English Everyday — Environment Variables
# ======================================================
# Copy to .env and fill in your values

# Server
NODE_ENV=development
PORT=5000

# Database
DATABASE_URL=postgresql://see_user:see_password@localhost:5432/see_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=see_db
DB_USER=see_user
DB_PASSWORD=see_password

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars
JWT_REFRESH_EXPIRES=30d

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Facebook OAuth
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# OpenAI
OPENAI_API_KEY=sk-...

# Google Cloud
GOOGLE_CLOUD_PROJECT_ID=your_project_id
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Firebase
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@project.iam.gserviceaccount.com

# AWS
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
AWS_S3_BUCKET=smart-english-everyday-media

# Email (SendGrid)
SENDGRID_API_KEY=SG.xxx
EMAIL_FROM=noreply@smartenglisheveryday.com
EMAIL_FROM_NAME=Smart English Everyday

# Frontend
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5

# Logging
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# App Store (for CI/CD)
# KEYSTORE_BASE64=base64_encoded_keystore
# KEYSTORE_PASSWORD=
# KEY_ALIAS=
# KEY_PASSWORD=
